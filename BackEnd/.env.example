# Copy this file to .env and fill in your values.
# For paper trading you can leave KIS and Discord empty.

# ----- KIS API (required for live trading only) -----
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NUMBER=
KIS_ACCOUNT_PROD=01

# ----- Discord notifications (optional) -----
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=0

# ----- Dashboard (optional; defaults shown) -----
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8000
# DASHBOARD_USER=admin
# DASHBOARD_PASS=changeme
# DASHBOARD_ALLOWED_IPS=127.0.0.1
# DASHBOARD_SESSION_TIMEOUT=30
